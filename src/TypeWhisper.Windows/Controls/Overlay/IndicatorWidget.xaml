<UserControl x:Class="TypeWhisper.Windows.Controls.Overlay.IndicatorWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels">
    <Ellipse Width="10" Height="10" VerticalAlignment="Center">
        <Ellipse.Style>
            <Style TargetType="Ellipse">
                <Setter Property="Fill" Value="#888"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static vm:DictationState.Recording}">
                        <Setter Property="Fill" Value="#FF4444"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static vm:DictationState.Processing}">
                        <Setter Property="Fill" Value="#FFaa00"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static vm:DictationState.Inserting}">
                        <Setter Property="Fill" Value="#44cc44"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static vm:DictationState.Error}">
                        <Setter Property="Fill" Value="#FF0000"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Ellipse.Style>
    </Ellipse>
</UserControl>
