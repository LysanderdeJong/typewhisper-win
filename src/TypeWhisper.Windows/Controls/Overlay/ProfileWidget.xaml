<UserControl x:Class="TypeWhisper.Windows.Controls.Overlay.ProfileWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters">
    <UserControl.Resources>
        <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVis"/>
    </UserControl.Resources>
    <Border Background="#1A3A6B" CornerRadius="6" Padding="5,2"
            Visibility="{Binding ActiveProfileName, Converter={StaticResource NonEmptyToVis}}">
        <TextBlock Text="{Binding ActiveProfileName}"
                   Foreground="#5B9FFF" FontSize="10"
                   MaxWidth="80" TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center"/>
    </Border>
</UserControl>
