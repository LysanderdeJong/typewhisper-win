<UserControl x:Class="TypeWhisper.Windows.Controls.Overlay.TimerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters">
    <UserControl.Resources>
        <conv:SecondsToTimerConverter x:Key="SecondsToTimer"/>
    </UserControl.Resources>
    <TextBlock Text="{Binding RecordingSeconds, Converter={StaticResource SecondsToTimer}}"
               Foreground="#999" FontSize="11" FontFamily="Consolas"
               VerticalAlignment="Center"/>
</UserControl>
