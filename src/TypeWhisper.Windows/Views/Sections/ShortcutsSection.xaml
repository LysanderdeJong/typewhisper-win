<UserControl x:Class="TypeWhisper.Windows.Views.Sections.ShortcutsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TypeWhisper.Windows.Controls">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28" MaxWidth="860">
            <Border Style="{StaticResource SettingsHeroCardStyle}">
                <StackPanel>
                    <TextBlock Text="Shortcuts" Style="{StaticResource PageEyebrowStyle}"/>
                    <TextBlock Text="Keep capture keyboard-first"
                               Style="{StaticResource PageTitleStyle}"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="All shortcut entry points now live on one page: the main dictation flows plus the prompt palette."
                               Style="{StaticResource PageSubtitleStyle}"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <UniformGrid Columns="2">
                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Hybrid dictation" Style="{StaticResource SectionHeaderStyle}" FontSize="16" Margin="0,0,0,6"/>
                        <TextBlock Text="Short press and hold behavior in one shortcut."
                                   Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,12"/>
                        <controls:HotkeyRecorderControl Hotkey="{Binding Settings.PushToTalkHotkey}" AllowModifierOnly="True" Width="220" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Toggle-only" Style="{StaticResource SectionHeaderStyle}" FontSize="16" Margin="0,0,0,6"/>
                        <TextBlock Text="Start and stop dictation with a dedicated shortcut."
                                   Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,12"/>
                        <controls:HotkeyRecorderControl Hotkey="{Binding Settings.ToggleOnlyHotkey}" AllowModifierOnly="True" Width="220" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Hold-only" Style="{StaticResource SectionHeaderStyle}" FontSize="16" Margin="0,0,0,6"/>
                        <TextBlock Text="Pure push-to-talk without toggle mode."
                                   Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,12"/>
                        <controls:HotkeyRecorderControl Hotkey="{Binding Settings.HoldOnlyHotkey}" AllowModifierOnly="True" Width="220" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Prompt palette" Style="{StaticResource SectionHeaderStyle}" FontSize="16" Margin="0,0,0,6"/>
                        <TextBlock Text="Open the AI prompt palette without starting dictation."
                                   Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,12"/>
                        <controls:HotkeyRecorderControl Hotkey="{Binding Settings.PromptPaletteHotkey}" AllowModifierOnly="True" Width="220" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
