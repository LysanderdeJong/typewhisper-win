<UserControl x:Class="TypeWhisper.Windows.Views.Sections.AppearanceSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:TypeWhisper.Core.Models;assembly=TypeWhisper.Core"
             xmlns:overlay="clr-namespace:TypeWhisper.Windows.Controls.Overlay"
             xmlns:vms="clr-namespace:TypeWhisper.Windows.ViewModels">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,22,28,28" MaxWidth="980">
            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="Overlay layout" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Position" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"
                                          SelectedValue="{Binding Settings.OverlayPosition}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="Top" Tag="{x:Static models:OverlayPosition.Top}"/>
                                    <ComboBoxItem Content="Bottom" Tag="{x:Static models:OverlayPosition.Bottom}"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Left content" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"
                                          ItemsSource="{x:Static vms:SettingsViewModel.WidgetOptions}"
                                          SelectedValue="{Binding Settings.OverlayLeftWidget}"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="DisplayName"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Background="#18FFFFFF"/>

                        <Border Grid.Row="4" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Right content" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"
                                          ItemsSource="{x:Static vms:SettingsViewModel.WidgetOptions}"
                                          SelectedValue="{Binding Settings.OverlayRightWidget}"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="DisplayName"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="Preview" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Border Background="#120C1118" CornerRadius="14" Padding="28" MinHeight="180" Margin="16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Overlay indicator"
                                       Foreground="{StaticResource HintBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                            <Border Background="#E6121822"
                                    BorderBrush="#22507BAA"
                                    BorderThickness="1"
                                    CornerRadius="26"
                                    Padding="16,12"
                                    HorizontalAlignment="Center"
                                    MinWidth="340">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <overlay:OverlayWidgetHost Grid.Column="0"
                                                               WidgetType="{Binding Settings.OverlayLeftWidget}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="Recording"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Graphite body, brighter azure focus, and denser runtime metadata."
                                                   Foreground="{StaticResource HintBrush}"
                                                   FontSize="11"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="220"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <overlay:OverlayWidgetHost Grid.Column="2"
                                                               WidgetType="{Binding Settings.OverlayRightWidget}"
                                                               VerticalAlignment="Center"
                                                               Margin="12,0,0,0"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
