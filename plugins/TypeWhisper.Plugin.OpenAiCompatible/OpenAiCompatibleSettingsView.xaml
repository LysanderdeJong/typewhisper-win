<UserControl x:Class="TypeWhisper.Plugin.OpenAiCompatible.OpenAiCompatibleSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="0,4" MaxWidth="500">
        <!-- Server URL -->
        <TextBlock Text="Server URL" FontWeight="SemiBold" Margin="0,0,0,4" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="UrlBox" FontFamily="Consolas"
                     Text="http://localhost:11434" />
            <Button Grid.Column="1" Content="Verbinden" Margin="8,0,0,0" Padding="12,4"
                    Click="OnConnectClick" x:Name="ConnectButton" />
        </Grid>
        <TextBlock x:Name="ConnectionStatus" Margin="0,4,0,0" FontSize="12" />

        <!-- API Key (optional) -->
        <TextBlock Text="API Key (optional)" FontWeight="SemiBold" Margin="0,12,0,4" />
        <PasswordBox x:Name="ApiKeyBox" PasswordChanged="OnApiKeyChanged" />
        <TextBlock Text="Nicht nötig für lokale Server wie Ollama oder LM Studio"
                   FontSize="11" Foreground="Gray" Margin="0,2,0,0" />

        <!-- Models Section (hidden until connected) -->
        <StackPanel x:Name="ModelsSection" Visibility="Collapsed" Margin="0,12,0,0">
            <!-- Transcription Model -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Modelle" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Aktualisieren" Padding="8,2"
                        Click="OnRefreshClick" x:Name="RefreshButton" />
            </Grid>

            <!-- Fetched models pickers -->
            <StackPanel x:Name="PickerSection" Visibility="Collapsed">
                <TextBlock Text="Transkriptions-Modell" FontSize="12" Foreground="Gray" Margin="0,0,0,2" />
                <ComboBox x:Name="TranscriptionModelPicker" SelectionChanged="OnTranscriptionModelChanged"
                          DisplayMemberPath="Id" Margin="0,0,0,8" />

                <TextBlock Text="LLM-Modell" FontSize="12" Foreground="Gray" Margin="0,0,0,2" />
                <ComboBox x:Name="LlmModelPicker" SelectionChanged="OnLlmModelChanged"
                          DisplayMemberPath="Id" />
            </StackPanel>

            <!-- Manual entry fallback -->
            <StackPanel x:Name="ManualSection" Visibility="Collapsed">
                <TextBlock Text="Keine Modelle gefunden. Modellname manuell eingeben:"
                           FontSize="12" Foreground="Gray" Margin="0,0,0,4" />

                <TextBlock Text="Transkriptions-Modell" FontSize="12" Foreground="Gray" Margin="0,0,0,2" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ManualTranscriptionBox" FontFamily="Consolas" />
                    <Button Grid.Column="1" Content="Speichern" Margin="8,0,0,0" Padding="8,2"
                            Click="OnSaveManualTranscription" />
                </Grid>

                <TextBlock Text="LLM-Modell" FontSize="12" Foreground="Gray" Margin="0,0,0,2" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ManualLlmBox" FontFamily="Consolas" />
                    <Button Grid.Column="1" Content="Speichern" Margin="8,0,0,0" Padding="8,2"
                            Click="OnSaveManualLlm" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
